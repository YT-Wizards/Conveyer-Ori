# API keys and settings can ALSO be set through the UI at http://localhost:3000/settings
# Anything here is used as a fallback when the corresponding DB row is empty.

# ── Required ──────────────────────────────────────────────────────────────────

# Gemini — used to split your script into scenes.
# Free key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Pexels — source of all stock b-roll (video + photos).
# Free key: https://www.pexels.com/api/  (200 requests/hour, 20 000/month)
PEXELS_API_KEY=

# ai33.pro — voiceover via ElevenLabs voices (cheap proxy).
# Sign up + get key: https://ai33.pro
AI33PRO_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# Absolute path to ffmpeg if it isn't already in your system PATH.
# Windows example: C:\\ffmpeg\\bin\\ffmpeg.exe
# macOS Homebrew:  /opt/homebrew/bin/ffmpeg
FFMPEG_PATH=

# Where finished runs are written. Leave empty to use the default
# (~/.conveyer-ori/runs). Setting this also recreates the data/runs
# junction inside the project so file browsers can find your outputs.
CONVEYER_ORI_DATA_DIR=
